# ──────────────────────────────────────────────────────────────
# Friday Agent Studio & Toolkit (FAST) — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values you need:
#   cp .env.example .env
#
# Only ANTHROPIC_API_KEY is required to get started.
# Uncomment and configure additional integrations as needed.
# ──────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Platform settings ────────────────────────────────────────
# ATLAS_LOG_LEVEL=info              # debug | info | warn | error

# ── Bitbucket Cloud ─────────────────────────────────────────
# App password needs: repository:read, repository:write, pullrequest:write
# BITBUCKET_EMAIL=
# BITBUCKET_TOKEN=

# ── GitHub ───────────────────────────────────────────────────
# Personal access token with repo scope
# GH_TOKEN=

# ── Jira Cloud ───────────────────────────────────────────────
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_SITE=                        # e.g. acme.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# ── Port overrides ───────────────────────────────────────────
# Override host-side port mappings (container ports are fixed)
# FRIDAY_DAEMON_PORT=18080
# FRIDAY_LINK_PORT=13100
# FRIDAY_STUDIO_PORT=15200
# FRIDAY_PTY_PORT=17681
# FRIDAY_TUNNEL_PORT=19090

# ── Webhook tunnel ───────────────────────────────────────────
# Set for a stable public URL; omit for a random temporary URL each restart
# TUNNEL_TOKEN=
# Set to true to disable the Cloudflare tunnel entirely
# NO_TUNNEL=false
